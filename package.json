{
  "name": "wedding-os",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "env:check": "node scripts/env-check.mjs",
    "db:ensure": "node scripts/ensure-local-db.mjs",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "vendors:seed-gta": "node scripts/seed-gta-vendors.mjs",
    "rsvp:cleanup-links": "node scripts/cleanup-rsvp-token-duplicates.mjs",
    "smoke:core-flow": "node scripts/core-flow-smoke.mjs",
    "smoke:auth": "node scripts/auth-smoke.mjs",
    "smoke:crud": "node scripts/crud-smoke.mjs",
    "smoke:permissions": "node scripts/permissions-smoke.mjs",
    "smoke:beta": "node scripts/beta-smoke.mjs",
    "smoke:all": "npm run smoke:auth && npm run smoke:core-flow && npm run smoke:permissions && npm run smoke:crud && npm run smoke:beta",
    "e2e": "npm run build && playwright test",
    "e2e:ui": "playwright test --ui",
    "beta:doctor": "node scripts/beta-doctor.mjs",
    "beta:seed-invites": "node scripts/beta-seed-invites.mjs",
    "beta:backup": "node scripts/beta-backup.mjs",
    "beta:restore": "node scripts/beta-restore.mjs",
    "beta:dev": "npm run db:ensure && npm run prisma:migrate -- --name local_beta && npm run prisma:seed && npm run beta:doctor && npm run dev",
    "beta:tunnel": "cloudflared tunnel --url http://localhost:3000"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
